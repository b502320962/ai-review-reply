{
  "manifest_version": 3,
  "name": "AI Review Reply",
  "version": "2.0.0",
  "description": "AI-powered reply generator for Google Business, Yelp, and WeChat comments",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "identity"
  ],
  "host_permissions": [
    "https://api.deepseek.com/*",
    "https://*.supabase.co/*",
    "https://www.google.com/business/*",
    "https://business.google.com/*",
    "https://www.yelp.com/*",
    "https://mp.weixin.qq.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/business/*",
        "https://business.google.com/*",
        "https://www.yelp.com/*",
        "https://mp.weixin.qq.com/*"
      ],
      "js": ["lib/supabase-client.js", "content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
