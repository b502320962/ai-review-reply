{
  "manifest_version": 3,
  "name": "AI Review Reply - Smart Comment Responder",
  "version": "1.2.0",
  "description": "AI-powered tool to generate professional replies for Google Maps, Yelp, and WeChat Official Accounts.",
  "permissions": [
    "activeTab",
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://business.google.com/*",
    "https://www.yelp.com/*",
    "https://maps.google.com/*",
    "https://mp.weixin.qq.com/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://business.google.com/*",
        "https://www.yelp.com/*",
        "https://mp.weixin.qq.com/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
